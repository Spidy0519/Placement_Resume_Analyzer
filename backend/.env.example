# ============================================================
# ENVIRONMENT VARIABLES - PlacementResumeAnalyzer
# ============================================================
# STEP 1: Copy this file → rename it to ".env"
# STEP 2: Fill in your GROQ_API_KEY
# STEP 3: NEVER push .env to GitHub!
# ============================================================

# Get your FREE Groq API Key here → https://console.groq.com
# Sign up → Dashboard → API Keys → Create API Key → Copy
GROQ_API_KEY=your_groq_api_key_here
CHATBOT_API_KEY=your_groq_api_key_here
ROADMAP_API_KEY=your_groq_api_key_here

# Server Settings (keep as is for local development)
APP_HOST=0.0.0.0
APP_PORT=8000

# Set this to your frontend URL in production
# Example: FRONTEND_URL=https://myapp.vercel.app
FRONTEND_URL=http://localhost:8000
